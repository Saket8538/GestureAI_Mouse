# ═══════════════════════════════════════════════════════════════════════════════
#  Proton AI Assistant — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in the values for your chosen provider.
#  Only configure the provider you want to use — leave the rest blank.
#
#  Step 1:  Copy this file      →  cp .env.example .env
#  Step 2:  Set your provider   →  PROTON_AI_PROVIDER=gemini
#  Step 3:  Set the API key     →  PROTON_GEMINI_KEY=your-key-here
#  Step 4:  (optional) Change the model name below
#
#  The .env file is git-ignored so your keys stay safe.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Provider Selection ────────────────────────────────────────────────────────
#  Choose ONE: gemini | openai | azure_openai | claude | ollama | none
PROTON_AI_PROVIDER=none

# ── Google Gemini ─────────────────────────────────────────────────────────────
#  Get key: https://aistudio.google.com/app/apikey
PROTON_GEMINI_KEY=
PROTON_GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI ────────────────────────────────────────────────────────────────────
#  Get key: https://platform.openai.com/api-keys
PROTON_OPENAI_KEY=
PROTON_OPENAI_MODEL=gpt-4o-mini

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
#  Get from Azure Portal → your OpenAI resource → Keys and Endpoint
PROTON_AZURE_OPENAI_KEY=
PROTON_AZURE_OPENAI_ENDPOINT=
PROTON_AZURE_OPENAI_DEPLOYMENT=
PROTON_AZURE_OPENAI_API_VERSION=2024-06-01

# ── Anthropic Claude ──────────────────────────────────────────────────────────
#  Get key: https://console.anthropic.com/settings/keys
PROTON_CLAUDE_KEY=
PROTON_CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Ollama (local, free, no key needed) ───────────────────────────────────────
#  Install: https://ollama.com  then run: ollama pull llama3.2
PROTON_OLLAMA_URL=http://localhost:11434
PROTON_OLLAMA_MODEL=llama3.2
